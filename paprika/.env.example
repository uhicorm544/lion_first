# Backend (Spring Boot)
DB_HOST=
DB_USERNAME=
DB_PASSWORD=

# Cloudinary (이미지 업로드)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# OAuth (Google, Naver, GitHub) — 각자 필요 시 발급
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CLIENT_ID_PROD=
GITHUB_CLIENT_SECRET_PROD=

# JWT
JWT_SECRET=

# Frontend (Next.js) — frontend/.env.local 에 별도로 작성
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=http://localhost:8080
NEXT_PUBLIC_GOOGLE_MAP_KEY=
